rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users can only read/write their own notifications subcollection.
    // Backend uses Firebase Admin and bypasses these rules.
    // Frontend signs in with custom token (uid = backend userId string).
    match /users/{userId}/notifications/{notificationId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
