rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Notifications: only the owner can read/update their notifications ---
    match /users/{userId}/notifications/{notificationId} {

      function isOwner() {
        return request.auth != null && request.auth.uid == userId;
      }

      // User can read their own notifications
      allow read: if isOwner();

      // User can update their own notifications (e.g. mark as read)
      allow update: if isOwner();

      // Only backend (Admin SDK) should create/delete; rules don't apply to Admin SDK anyway
      allow create, delete: if false;
    }

    // --- Chats: only participants can see or create/update a chat ---
    match /chats/{chatId} {

      function isParticipantOnCreate() {
        // For new docs, use the incoming data
        return request.auth != null
          && int(request.auth.uid) in request.resource.data.participants;
      }

      function isParticipantOnExisting() {
        // For existing docs, use stored data
        return request.auth != null
          && int(request.auth.uid) in resource.data.participants;
      }

      // Create a chat only if the current user is one of the participants
      allow create: if isParticipantOnCreate();

      // Read / update / delete only if the user is a participant
      allow read, update, delete: if isParticipantOnExisting();
    }

    // --- Messages: only participants can see messages in a chat ---
    match /chats/{chatId}/messages/{messageId} {

      function isChatParticipant() {
        return request.auth != null
          && int(request.auth.uid)
             in get(/databases/$(database)/documents/chats/$(chatId))
                  .data.participants;
      }

      // Participants can read messages in their chat
      allow read: if isChatParticipant();

      // Only participants can send messages, and senderId must match auth.uid
      allow create: if isChatParticipant()
        && request.resource.data.senderId == int(request.auth.uid);

      // Let participants update messages (e.g. mark as read); keeps it simple
      allow update: if isChatParticipant();

      // Optionally, you can restrict delete; for now, disallow
      allow delete: if false;
    }
  }
}